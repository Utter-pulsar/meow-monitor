<?xml version='1.0' encoding='utf-8'?>
<vdd_settings>
    <monitors>
        <count>1</count>
    </monitors>
    <gpu>
        <friendlyname>default</friendlyname>
    </gpu>
	<global>
		<!--These are global refreshrates, any you add in here, will be replicated to all resolutions-->
		<g_refresh_rate>60</g_refresh_rate>
	</global>
    <resolutions>
        <!-- TURZX bar-screen: the panel is 1920x464 landscape. -->
        <resolution>
            <width>1920</width>
            <height>464</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
        <!-- Fallback strips in case 464 is rejected by IddCx/Windows -->
        <resolution>
            <width>1920</width>
            <height>480</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
        <resolution>
            <width>1920</width>
            <height>540</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
        <!-- Standard modes kept for the crop-fallback path and general sanity -->
        <resolution>
            <width>1920</width>
            <height>1080</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
        <resolution>
            <width>1366</width>
            <height>768</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
    </resolutions>
    <options>
		<CustomEdid>false</CustomEdid>
		<PreventSpoof>false</PreventSpoof>
		<EdidCeaOverride>false</EdidCeaOverride>
		<HardwareCursor>false</HardwareCursor>
		<SDR10bit>false</SDR10bit>
		<HDRPlus>false</HDRPlus>
		<logging>false</logging>
        <debuglogging>false</debuglogging>
	</options>
</vdd_settings>
